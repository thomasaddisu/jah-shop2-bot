# ============================================================
# JAH SHOP BOT — ENVIRONMENT CONFIGURATION
# ============================================================

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin Telegram User IDs (comma-separated, no spaces)
ADMIN_IDS=123456789,987654321

# Support Username (without @)
SUPPORT_USERNAME=your_support_username

# USDT BEP20 Wallet Address
USDT_ADDRESS=0xYourUSDTBEP20AddressHere

# Bank Transfer Details
BANK_DETAILS=Bank Name: YourBank | Account: 1234567890 | Name: Your Name

# Bot Settings
BOT_NAME=Jah Shop
CURRENCY=USD
DEBUG=false
